{
  "name": "pixvitta",
  "productName": "Pixvitta",
  "version": "0.1.4",
  "description": "A lightweight desktop image and video viewer.",
  "desktopName": "pixvitta.desktop",
  "private": true,
  "author": "Raul Rodrigues",
  "license": "GPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/raulferrodrigues/pixvitta.git"
  },
  "bugs": {
    "url": "https://github.com/raulferrodrigues/pixvitta/issues"
  },
  "homepage": "https://github.com/raulferrodrigues/pixvitta#readme",
  "main": "dist-electron/main/main.js",
  "scripts": {
    "icon:generate": "node scripts/generate-icon.mjs stable",
    "icon:generate:dev": "node scripts/generate-icon.mjs dev",
    "dev": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "build:electron": "esbuild src/main/main.ts src/preload/preload.ts --bundle --platform=node --external:electron --external:electron-updater --format=cjs --outdir=dist-electron",
    "electron:dev": "pnpm build:electron && concurrently -k \"pnpm dev\" \"wait-on tcp:5173 && env -u ELECTRON_RUN_AS_NODE PIXVITTA_BUILD_FLAVOR=dev VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "test": "esbuild src/main/updates/updateStatus.test.ts --bundle --platform=node --format=cjs --outfile=.tmp/updateStatus.test.cjs && node --test .tmp/updateStatus.test.cjs",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "build": "vite build && pnpm build:electron",
    "validate": "pnpm test && pnpm typecheck && pnpm build",
    "dist": "pnpm dist:mac",
    "dist:mac": "pnpm icon:generate && pnpm build && electron-builder --mac dmg zip --publish never",
    "dist:linux": "pnpm icon:generate && pnpm build && node scripts/build-linux.mjs stable",
    "dist:linux:dev": "pnpm icon:generate:dev && pnpm build && node scripts/build-linux.mjs dev",
    "dist:deb": "pnpm icon:generate && pnpm build && node scripts/build-linux.mjs stable deb",
    "dist:deb:dev": "pnpm icon:generate:dev && pnpm build && node scripts/build-linux.mjs dev deb",
    "dist:dir": "pnpm icon:generate && pnpm build && electron-builder --mac dir",
    "gt:generate": "gt generate",
    "release:check": "node scripts/verify-release-env.mjs",
    "release:mac": "pnpm release:check && pnpm validate && pnpm dist"
  },
  "dependencies": {
    "@radix-ui/react-dropdown-menu": "2.1.20",
    "@tanstack/react-virtual": "^3.14.2",
    "electron-updater": "^6.8.3",
    "gt-react": "^10.20.1",
    "lucide-react": "^0.561.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "electron": "^39.2.7",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.0",
    "gt": "^2.14.50",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "wait-on": "^9.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "electron-winstaller"
    ]
  },
  "build": {
    "appId": "com.raulrodrigues.pixvitta",
    "productName": "Pixvitta",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json"
    ],
    "asar": true,
    "mac": {
      "category": "public.app-category.photography",
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null,
      "fileAssociations": [
        {
          "ext": [
            "jpg",
            "jpeg",
            "png",
            "gif",
            "webp",
            "bmp",
            "avif",
            "svg",
            "ico"
          ],
          "name": "Pixvitta Image",
          "role": "Viewer",
          "rank": "Default"
        },
        {
          "ext": [
            "mp4",
            "m4v",
            "mov",
            "webm",
            "ogv",
            "ogg"
          ],
          "name": "Pixvitta Video",
          "role": "Viewer",
          "rank": "Default"
        }
      ]
    },
    "linux": {
      "category": "Graphics",
      "icon": "build/icons",
      "desktop": {
        "entry": {
          "StartupWMClass": "pixvitta"
        }
      },
      "extraResources": [
        {
          "from": "build/runtime-icon.png",
          "to": "icon.png"
        }
      ],
      "maintainer": "Raul Rodrigues <48070394+raulferrodrigues@users.noreply.github.com>",
      "target": [
        "AppImage"
      ],
      "mimeTypes": [
        "image/jpeg",
        "image/png",
        "image/gif",
        "image/webp",
        "image/bmp",
        "image/avif",
        "image/svg+xml",
        "image/x-icon",
        "video/mp4",
        "video/x-m4v",
        "video/quicktime",
        "video/webm",
        "video/ogg"
      ]
    },
    "appImage": {
      "artifactName": "Pixvitta.AppImage"
    },
    "deb": {
      "artifactName": "Pixvitta-${version}-${arch}.${ext}"
    },
    "dmg": {
      "artifactName": "Pixvitta-${version}-${arch}.${ext}",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "publish": [
      {
        "provider": "github",
        "owner": "raulferrodrigues",
        "repo": "pixvitta"
      }
    ],
    "electronUpdaterCompatibility": ">= 2.16"
  }
}
